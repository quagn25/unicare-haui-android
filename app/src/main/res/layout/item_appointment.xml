<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Trạng thái -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chờ xác nhận"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_status_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:layout_marginBottom="10dp"/>

        <!-- Tên bác sĩ -->
        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>

        <!-- Chuyên khoa -->
        <TextView
            android:id="@+id/tvSpecialty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/primary_blue"
            android:layout_marginTop="2dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/black" android:layout_marginVertical="10dp"/>

        <!-- Ngày -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="📅" android:textSize="13sp"/>
            <TextView android:id="@+id/tvDate" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Giờ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="🕐" android:textSize="13sp"/>
            <TextView android:id="@+id/tvTimeSlot" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <!-- Địa chỉ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="6dp">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="📍" android:textSize="13sp"/>
            <TextView android:id="@+id/tvAddress" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textSize="12sp" android:textColor="@color/black"
                android:maxLines="2"/>
        </LinearLayout>

        <!-- Phí -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                android:text="💰" android:textSize="13sp"/>
            <TextView android:id="@+id/tvFee" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="#E84040" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>