<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/background"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.patients.profile.ui.PersonFragment">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="10dp"
        android:orientation="vertical">

        <TableRow
            android:layout_marginTop="20dp"
            android:padding="10dp"
            android:background="@drawable/circleconner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" >

            <com.google.android.material.imageview.ShapeableImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginEnd="15dp"
                android:scaleType="centerCrop"
                android:src="@drawable/macdinh"
                app:shapeAppearanceOverlay="@style/circleImage"/>


            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:textStyle="bold"
                android:textSize="20dp"
                android:text="TextView" />
        </TableRow>


        <LinearLayout
            android:background="@drawable/circleconner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textView8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:drawablePadding="10dp"
                android:drawableStart="@drawable/outline_lab_profile_24"
                android:drawableTint="#2196F3"
                android:text="Hồ sơ y tế" />

            <View
                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:layout_height="1dp"
                android:layout_marginTop="15dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/textView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:drawablePadding="10dp"
                android:drawableStart="@drawable/outline_share_24"
                android:drawableTint="#2196F3"
                android:text="Chia sẻ ứng dụng" />

            <View
                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:layout_height="1dp"
                android:layout_marginTop="15dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/textView10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:drawablePadding="10dp"
                android:drawableStart="@drawable/outline_lock_open_circle_24"
                android:drawableTint="#2196F3"
                android:text="Thay đổi mật khẩu" />

            <View
                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:layout_height="1dp"
                android:layout_marginTop="15dp"
                android:background="#E0E0E0" />


            <TextView
                android:id="@+id/textView11"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="15dp"
                android:drawablePadding="10dp"
                android:drawableStart="@drawable/outline_person_cancel_24"
                android:drawableTint="#2196F3"
                android:text="Yêu cầu xoá tài khoản" />
        </LinearLayout>

        <Button
            android:id="@+id/button2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            app:backgroundTint="#295FD0"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"
            android:text="Đăng xuất" />



    </LinearLayout>

</FrameLayout>