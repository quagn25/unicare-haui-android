<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header (Màu xanh dương) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0066FF"
        android:padding="16dp">

        <!-- Tiêu đề và Nút Lọc -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch khám"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_centerInParent="true"/>

            <ImageView
                android:id="@+id/btn_filter"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:icon="@drawable/ic_location"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:tint="#FFFFFF"/>
        </RelativeLayout>

        <!-- Thanh Tìm kiếm (Màu xanh đậm) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:icon="@drawable/ic_location"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:icon="@drawable/ic_location"
                app:tint="#8A9BB8" />

            <EditText
                android:id="@+id/edt_search"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@null"
                android:hint="Tìm theo mã phiếu khám, tên bệnh n..."
                android:textColorHint="#8A9BB8"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:singleLine="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Khu vực nội dung chính -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Trạng thái Trống (Empty State) - Giống hệt ảnh -->
        <LinearLayout
            android:id="@+id/layout_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ImageView
                android:layout_width="250dp"
                android:layout_height="180dp"
                android:src="@drawable/img_empty_appointment"
                android:scaleType="fitCenter"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bạn chưa có lịch khám"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch khám của bạn sẽ được hiển thị tại đây."
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- Danh sách Lịch khám (Sẽ hiện lên khi có data, tạm thời ẩn) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcv_appointments"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipToPadding="false"
            android:padding="16dp"/>

    </FrameLayout>
</LinearLayout>