<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F4F7">

    <!-- Header xanh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/primary_blue"
        android:paddingTop="40dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="12dp">

        <!-- Back + Search -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/white"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_search_field"
                android:paddingHorizontal="12dp"
                android:hint="Tên bác sĩ, triệu chứng, chuyên khoa"
                android:textColorHint="#9CA3AF"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true"/>

            <!-- Chỉ giữ lại nút Bộ lọc -->
            <TextView
                android:id="@+id/btnFilter"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:text="Bộ lọc"
                android:textColor="@color/primary_blue"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:background="@drawable/bg_search_field"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Thông tin bộ lọc đang áp dụng -->
        <TextView
            android:id="@+id/tvFilterInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tất cả bác sĩ"
            android:textColor="#CCE0FF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"/>

    </LinearLayout>

    <!-- Danh sách bác sĩ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewDoctors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>